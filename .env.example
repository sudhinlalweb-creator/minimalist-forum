# Neon serverless Postgres — pooled connection string from the Neon console.
# Copy this file to .env.local and fill in real values.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Canonical origin. Drives canonical tags, sitemap.xml, Open Graph URLs and
# llms.txt in Phase 4 — must be the real public origin in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Auth.js (Phase 2). Generate with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth (Phase 2)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
